# --- SSH target ---
# user@host of the VPS Claude is allowed to operate on. SSH key auth assumed
# (your ~/.ssh/config + agent take care of credentials).
# Prefer a non-root user with passwordless sudo over a docker group membership.
INFRA_SSH_HOST=deploy@vps.example.com

# Path on the SSH target where the compose stack lives.
INFRA_COMPOSE_DIR=/opt/your-stack

# Public domain Caddy / your reverse proxy terminates TLS on. Used by
# service_url to build https://<service>.<domain> and probe it.
INFRA_PUBLIC_DOMAIN=example.com

# --- Safety controls ---
# Comma-separated allowlist of services the write tools (restart, etc.) may touch.
# Anything not listed is rejected even with confirm=true.
# Start with the minimum set you actually need to bounce — extend deliberately.
INFRA_ALLOWED_SERVICES=api,web,caddy

# Max log lines a single infra_logs call can return (clamps the LLM's request).
INFRA_MAX_LOG_LINES=500

# --- GitHub deploys lookup (optional) ---
# Used by infra_deploys to list recent workflow runs. Set to a GH token with
# 'actions:read' scope. Without it the tool degrades to "not configured".
GITHUB_TOKEN=
# Repos to surface in infra_deploys (comma-separated owner/repo pairs).
INFRA_DEPLOY_REPOS=your-org/your-infra,your-org/your-app

LOG_LEVEL=INFO
